# Image published by GitHub Actions → GHCR
JUPYTERHUB_IMAGE=ghcr.io/kumpecloud/jupyterhubdeployment:latest

# Host port for the Hub UI
JUPYTERHUB_PORT=8000

# Shared Docker network (Hub + user notebook containers)
DOCKER_NETWORK_NAME=jupyterhub_network

# Single-user notebook image spawned per login
DOCKER_JUPYTER_IMAGE=quay.io/jupyter/minimal-notebook:latest
# Pre-pull on the host: docker pull "$DOCKER_JUPYTER_IMAGE"
DOCKER_PULL_POLICY=ifnotpresent
# First spawn can exceed 180s while the notebook image downloads
DOCKER_SPAWNER_START_TIMEOUT=300

# Absolute host paths next to docker-compose.yml (required for DockerSpawner binds).
# Example on the VM after cd into the compose directory:
#   DATA_HOST_PATH=/home/kumpeapps-bot-deploy/.../data
#   WORKSPACES_HOST_PATH=/home/kumpeapps-bot-deploy/.../workspaces
DATA_HOST_PATH=
WORKSPACES_HOST_PATH=

# Encrypts auth_state (workspace grants). Generate: openssl rand -hex 32
JUPYTERHUB_CRYPT_KEY=

# Comma-separated admin usernames (must match Logto username claim values)
JUPYTERHUB_ADMIN_USERS=admin

# Optional allow-list (empty = allow all authenticated Logto users)
# JUPYTERHUB_ALLOWED_USERS=alice,bob

# ---------------------------------------------------------------------------
# Idle culling
# ---------------------------------------------------------------------------
# Stop running user servers after this much inactivity (seconds). Default 1h.
IDLE_CULL_ENABLED=true
IDLE_CULL_TIMEOUT_SECONDS=3600
# How often to check (default: half of timeout)
# IDLE_CULL_EVERY_SECONDS=1800

# Delete Hub *users* who have not been active for this many days (0 = disabled).
# They can log in again later. Does NOT delete ./data/users/<name> or shared workspaces.
# INACTIVE_USER_CULL_DAYS=30
# INACTIVE_USER_CULL_EVERY_SECONDS=86400

# ---------------------------------------------------------------------------
# Logto OIDC (AUTHENTICATOR=generic)
# Create a Traditional Web / Python app; Redirect URI = OAUTH_CALLBACK_URL.
# API resource indicator: OAUTH_RESOURCE (permissions like jupyterhub:workspace:kumpe3d).
# M2M app polls that resource's scopes and Hub requests them on every login.
# After adding a new workspace permission: wait for poll, then logout/login once.
# ---------------------------------------------------------------------------
AUTHENTICATOR=generic

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_CALLBACK_URL=https://jupyter.example.com/hub/oauth_callback

# Replace with your Logto endpoint (Cloud tenant or self-hosted URL)
LOGTO_ENDPOINT=https://auth.example.com
OAUTH_AUTHORIZE_URL=https://auth.example.com/oidc/auth
OAUTH_TOKEN_URL=https://auth.example.com/oidc/token
OAUTH_USERDATA_URL=https://auth.example.com/oidc/me

OAUTH_RESOURCE=https://jupyter.kumpe.app
OAUTH_USERNAME_CLAIM=username
OAUTH_SCOPE=openid,profile,email
# OAUTH_USERDATA_URL is unused when OAUTH_RESOURCE is set (profile comes from ID token)

# Machine-to-machine app with Management API access (read API resources/scopes)
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=
# Management API resource indicator from Logto Console
# Custom/self-hosted Logto often uses https://default.<domain>/api
LOGTO_MANAGEMENT_API_RESOURCE=https://default.kumpe.app/api
WORKSPACE_SCOPE_PREFIX=jupyter:workspace:
WORKSPACE_SCOPE_POLL_SECONDS=300

# Permissions in Logto must match this prefix, e.g. jupyter:workspace:public
# Create them on API resource OAUTH_RESOURCE (https://jupyter.kumpe.app).

# --- Local/dev without Logto (AUTHENTICATOR=dummy) ---
# AUTHENTICATOR=dummy
# DUMMY_PASSWORD=

# --- GitHub OAuth (AUTHENTICATOR=github) ---
# AUTHENTICATOR=github
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_CALLBACK_URL=https://jupyter.example.com/hub/oauth_callback
# GITHUB_ALLOWED_ORGANIZATIONS=my-org
