# Image published by GitHub Actions → GHCR
JUPYTERHUB_IMAGE=ghcr.io/kumpecloud/jupyterhubdeployment:latest

# Host port for the Hub UI
JUPYTERHUB_PORT=8000

# Shared Docker network (Hub + user notebook containers)
DOCKER_NETWORK_NAME=jupyterhub_network

# Single-user notebook image spawned per login
DOCKER_JUPYTER_IMAGE=quay.io/jupyter/minimal-notebook:latest

# Comma-separated admin usernames (must match Logto username claim values)
JUPYTERHUB_ADMIN_USERS=admin

# Optional allow-list (empty = allow all authenticated users)
# JUPYTERHUB_ALLOWED_USERS=alice,bob

# ---------------------------------------------------------------------------
# Logto OIDC (AUTHENTICATOR=generic)
# Create a "Traditional Web" app in Logto Console and set Redirect URI to
# OAUTH_CALLBACK_URL below.
# Discovery: https://<tenant>.logto.app/oidc/.well-known/openid-configuration
# ---------------------------------------------------------------------------
AUTHENTICATOR=generic

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_CALLBACK_URL=https://jupyter.example.com/hub/oauth_callback

# Replace <tenant> with your Logto endpoint (Cloud tenant or self-hosted URL)
OAUTH_AUTHORIZE_URL=https://<tenant>.logto.app/oidc/auth
OAUTH_TOKEN_URL=https://<tenant>.logto.app/oidc/token
OAUTH_USERDATA_URL=https://<tenant>.logto.app/oidc/me

# Logto username claim; use "email" or "sub" if username is not set on users
OAUTH_USERNAME_CLAIM=username
OAUTH_SCOPE=openid,profile,email

# --- Local/dev without Logto (AUTHENTICATOR=dummy) ---
# AUTHENTICATOR=dummy
# DUMMY_PASSWORD=

# --- GitHub OAuth (AUTHENTICATOR=github) ---
# AUTHENTICATOR=github
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_CALLBACK_URL=https://jupyter.example.com/hub/oauth_callback
# GITHUB_ALLOWED_ORGANIZATIONS=my-org
